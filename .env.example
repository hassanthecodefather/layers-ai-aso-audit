# ──────────────────────────────────────────────────────────────────────────
# ASO Audit Agent — environment
# Copy to `.env` (repo root) and adjust. Both `npm run dev` and
# `docker compose up` read this file.
# ──────────────────────────────────────────────────────────────────────────

# ── LLM ───────────────────────────────────────────────────────────────────
# LLM_PROVIDER selects the backend implementation (see src/llm/). Today the
# only provider is "ollama", which covers both Ollama Cloud and a local
# Ollama server — both speak the OpenAI-compatible protocol.
LLM_PROVIDER=ollama

# Option A — Ollama Cloud (hosted, recommended): a capable model, no local
# GPU needed. Create a key at https://ollama.com/settings/keys
#   LLM_BASE_URL=https://ollama.com/v1
#   LLM_MODEL=gemma4:31b-cloud
#   LLM_API_KEY=<your ollama key>
#
# Option B — local Ollama (free, offline): install from https://ollama.com,
# then `ollama pull gemma3:12b`. The audit emits a large structured result,
# so a 4B model is too small — use 12B+ (or a hosted model).
#   LLM_BASE_URL=http://localhost:11434/v1
#   LLM_MODEL=gemma3:12b
#   LLM_API_KEY=
#
# Defaults below target Ollama Cloud — fill in LLM_API_KEY.
LLM_BASE_URL=https://ollama.com/v1
LLM_MODEL=gemma4:31b-cloud
LLM_API_KEY=

# ── Scraping: Firecrawl (optional) ────────────────────────────────────────
# Selects the crawler implementation (see src/sources/crawler/). With a key,
# the FirecrawlCrawler adds the subtitle, promotional text and preview-video
# checks. Without one, the audit runs on Apple's free iTunes API alone and
# those three checks are flagged "not assessed" — not guessed.
# Free key: https://firecrawl.dev
FIRECRAWL_API_KEY=

# ── Server ────────────────────────────────────────────────────────────────
# Port the Mastra server listens on. The web app proxies to it.
PORT=4111
